# Application display name (used in FastAPI docs/title)
APP_NAME=
# Enable debug behavior (true/false)
DEBUG=
# Global API prefix for routes (e.g. /api/v1)
API_PREFIX=
# Allowed CORS origins separated by commas, or * for all
CORS_ORIGINS=

# Persistence backend selector: memory | postgres
PERSISTENCE_PROVIDER=

# Preferred in production: set only DATABASE_URL.
# Example: postgresql+asyncpg://user:password@host:5432/db_name
# Full async PostgreSQL URL used by the app at runtime
DATABASE_URL=

# Optional for local development when DATABASE_URL is empty.
# PostgreSQL host
DB_HOST=
# PostgreSQL port
DB_PORT=
# PostgreSQL database name
DB_NAME=
# PostgreSQL username
DB_USER=
# PostgreSQL password
DB_PASSWORD=

# Optional server-side fallback OpenAI API key
OPENAI_API_KEY=
# OpenAI model name used for expense parsing (defaults if empty)
OPENAI_MODEL=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=
